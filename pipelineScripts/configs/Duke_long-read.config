bashrc=/users/asorgen/.bashrc
ROOT=/projects/afodor_research3/asorgen/HCT_Gut_Resistome_Pipeline

seqPath=/projects/afodor_research2/datasets/Andermann_HTSF/NanoporeSeqs

sampleList=../pipelineScripts/sample_lists/ONT-Samples.txt

conda_init=/apps/pkg/anaconda3/2023.09/etc/profile.d/conda.sh
conda_envs=/users/asorgen/.conda/envs
BAKTA_ENV=${conda_envs}/bakta-env
BAKTA_DB=${ROOT}/databases/bakta/db/db

miniforge_init=/users/asorgen/miniforge3/etc/profile.d/conda.sh
AMRFINDER_ENV=/users/asorgen/miniforge3/envs/amrfinder
RGI_ENV=/users/asorgen/miniforge3/envs/rgi


# Email address to receive job completion updates
email=asorgen@charlotte.edu

# Module-specific parameters

# Pre-processing
    copy_opts="--partition=Orion --nodes=1 --ntasks-per-node=16 --mem-per-cpu=2GB --time=24:00:00 --mail-user=${email} --mail-type=END,FAIL"
    read_qc_opts="--partition=Orion --nodes=1 --ntasks-per-node=32 --mem=1200GB --time=50:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Assembly
    asm_opts="--partition=Orion --nodes=1 --ntasks-per-node=32 --mem=3900GB --time=120:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Evaluation
    eval_opts="--partition=Orion --nodes=1 --ntasks-per-node=16 --mem=8GB --time=01:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Kraken2
    k2_opts="--partition=Orion --nodes=1 --ntasks-per-node=16 --mem=256GB --time=01:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Binning    
    bin_opts="--partition=Orion --nodes=1 --ntasks-per-node=16 --mem=200GB --time=128:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Refinement
    refine_opts="--partition=Orion --nodes=1 --ntasks-per-node=48 --mem=256GB --time=05:00:00 --mail-user=${email} --mail-type=END,FAIL"

    max_completion=70
    min_contam=10


# Reassembly
    reassem_opts="--partition=Orion --nodes=1 --ntasks-per-node=48 --mem=1200GB --time=168:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Classification
    classify_opts="--partition=Orion --nodes=1 --ntasks-per-node=48 --mem=256GB --time=10:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Annotation
    annotate_opts="--partition=Orion --nodes=1 --ntasks-per-node=48 --mem=256GB --time=05:00:00 --mail-user=${email} --mail-type=END,FAIL"


# AMR detection
    amr_opts="--partition=Orion --nodes=1 --ntasks-per-node=8 --mem-per-cpu=8GB --time=05:00:00 --mail-user=${email} --mail-type=END,FAIL"


# Assembly Gene Profiling
    asm_profile_opts="--partition=Orion --nodes=1 --ntasks-per-node=24 --mem=80GB --time=48:00:00 --mail-user=${email} --mail-type=END,FAIL"   


# DO NOT CHANGE
readType=long_read
