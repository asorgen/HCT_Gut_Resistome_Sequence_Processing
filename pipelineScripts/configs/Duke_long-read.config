source "$(dirname "${BASH_SOURCE[0]}")/private.config"
bashrc=${HPC_HOME}/.bashrc
bash_profile=${HPC_HOME}/.bash_profile

# Root directory paths -----------------------------------------------------------------------------
    cohort=Duke
    read=long
    dataset=${cohort}_${read}
    ROOT=${HPC_PROJECTS}/HCT_Gut_Resistome_Study/HCT_Gut_Resistome_Sequence_Processing
    DATA_ROOT=${HPC_PROJECTS}/HCT_Gut_Resistome_Study/HCT_Gut_Resistome_Data/unprocessed/${cohort}
    PROCESSED_ROOT=${HPC_PROJECTS}/HCT_Gut_Resistome_Study/HCT_Gut_Resistome_Data/processed/${cohort}
    datasetDir=${DATA_ROOT}/${dataset}
    ScriptPath=${ROOT}/pipelineScripts/scripts
    module_functions=${ScriptPath}/helper_scripts/module_completion.sh
    moduleScriptPath=${ScriptPath}/${read}_scripts
    print_functions=${ROOT}/pipelineScripts/configs/functions.sh

# Raw sequence path --------------------------------------------------------------------------------
    seqPath=${SEQ_ROOT}/Andermann_HTSF/NanoporeSeqs

# Sample list --------------------------------------------------------------------------------------
    sampleList=${ROOT}/pipelineScripts/sample_lists/ONT-Samples.txt

# Choose modules to run ----------------------------------------------------------------------------
    heston=false
    full=true

    run_cp_raw=false
    run_pre_qc=false; run_trim=false; run_decontam=false
    run_asm=false; run_eval=false
    run_k2=false
    run_bin=false; run_refine=false; run_reassem=false
    run_classify=false; run_annotate=false
    run_amr_nt_asm=false
    run_rgi_bwt=false
    run_amr_aa_asm=false
    run_amr_aa_bin=false
    run_clean_up=false

    if $full; then
        run_cp_raw=true
        run_pre_qc=true; run_trim=true; run_decontam=true
        run_asm=true; run_eval=true
        run_k2=true
        run_bin=true; run_refine=true; run_reassem=true
        run_classify=true; run_annotate=true
        run_amr_nt_asm=false
        run_rgi_bwt=true
        run_amr_aa_asm=true
        run_amr_aa_bin=true
        run_clean_up=true
    fi

    if $heston; then
        run_cp_raw=true
        run_pre_qc=true; run_trim=true; run_decontam=true
        run_k2=true
        run_rgi_bwt=true
        run_clean_up=true
    fi

# Conda environments -------------------------------------------------------------------------------
    conda_init=/apps/pkg/anaconda3/2023.09/etc/profile.d/conda.sh
    conda_envs=${HPC_HOME}/.conda/envs
    miniforge_init=${HPC_HOME}/miniforge3/etc/profile.d/conda.sh

    bracken=${HPC_HOME}/PROGRAMS/Bracken-2.7/src
    BAKTA_ENV=${conda_envs}/bakta-env
    AMRFINDER_ENV=${HPC_HOME}/miniforge3/envs/amrfinderplus-4.0.3
    RGI_ENV=${HPC_HOME}/PROGRAMS/rgi_env/bin/activate
    ONT_ENV=${conda_envs}/ont-env

# Database paths -----------------------------------------------------------------------------------
    GRCh38_DB=${ROOT}/databases/GRCh38
    GRCh38_FASTA=${GRCh38_DB}/GRCh38.p14.fa    # Reference FASTA for minimap2 host decontamination
    AMR_DB=${ROOT}/databases/REFs
    CHECKM_DB=${ROOT}/databases/MY_CHECKM_FOLDER
    GTDBtk_DB=${ROOT}/databases/GTDBtk/release226
    KRAKEN2_DB=${ROOT}/databases/KRAKEN2-TESSA-DB
    BAKTA_DB=${ROOT}/databases/bakta/db/db

    CARD_DB=${HPC_SCRATCH}/RGI_databases/rgi_4.0.1

# Module directories -------------------------------------------------------------------------------
    raw_readDir=${datasetDir}/0.0_raw_reads
    pre_qcDir=${datasetDir}/0.1_pre_qc
    trimmed_Dir=${datasetDir}/0.3_sequence_trim       # No dedup (0.2) for ONT
    clean_readDir=${datasetDir}/0.4_host_decontamination
    assemblyDir=${datasetDir}/1.1_assembly
    evaluationDir=${datasetDir}/1.2_evaluation
    krakenDir=${datasetDir}/2.1_kraken2
    brackenDir=${datasetDir}/2.2_bracken
    binningDir=${datasetDir}/3.1_binning
    refinedbinDir=${datasetDir}/3.2_refine_bins
    reassemDir=${datasetDir}/3.3_reassemble_bins
    rgi_bwt_dir=${datasetDir}/5.4_rgi_bwt

# Email address to receive job completion updates --------------------------------------------------
    email=${email_long}

# Pre-QC -------------------------------------------------------------------------------------------
    pre_qc_opts="--partition=Orion --nodes=1 --cpus-per-task=8 --mem=64GB --time=02:00:00 --mail-user=${email} --mail-type=FAIL"
    R1_ext=fastq.gz

# Sequence trimming (Porechop adapter trimming + NanoFilt quality/length filtering) ----------------
    trim_opts="--partition=Orion --nodes=1 --cpus-per-task=16 --mem=128GB --time=24:00:00 --mail-user=${email} --mail-type=FAIL"
    nanofilt_min_quality=8          # Minimum mean read quality score (Phred)
    nanofilt_min_length=500         # Minimum read length (bp)

# Host decontamination (minimap2 map-ont + samtools) -----------------------------------------------
    decontam_opts="--partition=Orion --nodes=1 --cpus-per-task=32 --mem=64GB --time=024:00:00 --mail-user=${email} --mail-type=FAIL"

# Assembly -----------------------------------------------------------------------------------------
    asm_opts="--partition=Orion --nodes=1 --cpus-per-task=32 --mem=500GB --time=120:00:00 --mail-user=${email} --mail-type=FAIL"

# Evaluation ---------------------------------------------------------------------------------------
    eval_opts="--partition=Orion --nodes=1 --cpus-per-task=1 --mem=1GB --time=01:00:00 --mail-user=${email} --mail-type=FAIL"
    min_contig_len=1500             # Filter contigs shorter than this (bp)

# Kraken2 ------------------------------------------------------------------------------------------
    k2_opts="--partition=Orion --nodes=1 --cpus-per-task=16 --mem=256GB --time=01:00:00 --mail-user=${email} --mail-type=FAIL"

# Binning ------------------------------------------------------------------------------------------
    bin_opts="--partition=Orion --nodes=1 --cpus-per-task=16 --mem=200GB --time=128:00:00 --mail-user=${email} --mail-type=END,FAIL"

# Refinement ---------------------------------------------------------------------------------------
    refine_opts="--partition=Orion --nodes=1 --cpus-per-task=48 --mem=256GB --time=05:00:00 --mail-user=${email} --mail-type=END,FAIL"
    min_completion=70
    max_contam=10

# Reassembly ---------------------------------------------------------------------------------------
    reassem_opts="--partition=Orion --nodes=1 --cpus-per-task=48 --mem=1200GB --time=168:00:00 --mail-user=${email} --mail-type=END,FAIL"

# Classification -----------------------------------------------------------------------------------
    classify_opts="--partition=Orion --nodes=1 --cpus-per-task=48 --mem=256GB --time=10:00:00 --mail-user=${email} --mail-type=FAIL"

# Annotation ---------------------------------------------------------------------------------------
    annotate_opts="--partition=Orion --nodes=1 --cpus-per-task=32 --mem=32GB --time=05:00:00 --mail-user=${email} --mail-type=FAIL"

# NT AMR detection ---------------------------------------------------------------------------------
    amr_nt_opts="--partition=Orion --nodes=1 --cpus-per-task=8 --mem=8GB --time=05:00:00 --mail-user=${email} --mail-type=FAIL"

# RGI BWT AMR detection (read-based, ONT single-end) -----------------------------------------------
    rgi_bwt_opts="--partition=Orion --nodes=1 --cpus-per-task=16 --mem=64GB --time=3:00:00 --mail-user=${email} --mail-type=FAIL"

# AA AMR detection (assembly gene profiling) -------------------------------------------------------
    asm_profile_opts="--partition=Orion --nodes=1 --cpus-per-task=24 --mem=80GB --time=48:00:00 --mail-user=${email} --mail-type=FAIL"

# Pipeline clean up --------------------------------------------------------------------------------
    discard_opts="--partition=Orion --nodes=1 --cpus-per-task=1 --mem=1GB --time=00:05:00 --mail-user=${email} --mail-type=FAIL"


# DO NOT CHANGE
readType=long_read
