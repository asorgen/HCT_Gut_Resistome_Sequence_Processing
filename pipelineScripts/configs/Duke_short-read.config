bashrc=/users/asorgen/.bashrc
bash_profile=/users/asorgen/.bash_profile

# Root directory paths -----------------------------------------------------------------------------
    read=short
    ROOT=/projects/afodor_research3/asorgen/HCT_Gut_Resistome_Pipeline/sequence_processing
    ScriptPath=${ROOT}/pipelineScripts/scripts
    module_functions=${ScriptPath}/helper_scripts/module_completion.sh
    moduleScriptPath=${ScriptPath}/${read}_scripts

# Raw sequence path --------------------------------------------------------------------------------
    seqPath=/projects/afodor_research2/datasets/Andermann_HTSF/211103_UNC41-A00434_0385_AHKJV5DSX2

# Sample list --------------------------------------------------------------------------------------
    sampleList=${ROOT}/pipelineScripts/sample_lists/Samples.txt

# Choose modules to run ----------------------------------------------------------------------------
    heston=true
    full=false

    run_pre_qc=false; run_dedup=false; run_trim=false; run_decontam=false 
    run_asm=false; run_eval=false
    run_k2=false; run_m4=false
    run_bin=false; run_refine=false; run_reassem=false
    run_classify=false; run_annotate=false
    run_amr_nt_asm=false; run_amr_nt_bin=false
    run_shortbred=false; run_rgi_bwt=false
    run_amr_aa_asm=false; run_amr_aa_bin=false
    run_clean_up=false

    if $full; then
        run_pre_qc=true; run_dedup=true; run_trim=true; run_decontam=true 
        run_asm=true; run_eval=true
        run_k2=true; run_m4=false
        run_bin=true; run_refine=true; run_reassem=true
        run_classify=true; run_annotate=true
        run_shortbred=false; run_rgi_bwt=true
        run_amr_aa_asm=true; run_amr_aa_bin=true
    fi

    if $heston; then
        run_pre_qc=true; run_dedup=true; run_trim=true; run_decontam=true 
        run_k2=true; run_m4=false
        run_shortbred=false; run_rgi_bwt=true
    fi

# Conda environments -------------------------------------------------------------------------------
    conda_init=/apps/pkg/anaconda3/2023.09/etc/profile.d/conda.sh
    conda_envs=/users/asorgen/.conda/envs
    miniforge_init=/users/asorgen/miniforge3/etc/profile.d/conda.sh

    bracken=/users/asorgen/PROGRAMS/Bracken-2.7/src
    BAKTA_ENV=${conda_envs}/bakta-env
    AMRFINDER_ENV=/users/asorgen/miniforge3/envs/amrfinderplus-4.0.3
    RGI_ENV=/users/asorgen/miniforge3/envs/rgi

# Database paths -----------------------------------------------------------------------------------
    GRCh38_DB=${ROOT}/databases/GRCh38
    BMTAGGER_DB=${ROOT}/databases/BMTAGGER_INDEX
    AMR_DB=${ROOT}/databases/REFs
    CHECKM_DB=${ROOT}/databases/MY_CHECKM_FOLDER
    GTDBtk_DB=${ROOT}/databases/GTDBtk/release226
    KRAKEN2_DB=${ROOT}/databases/KRAKEN2-TESSA-DB
    BAKTA_DB=${ROOT}/databases/bakta/db/db
    SB_MARKERS=${ROOT}/databases/ShortBRED/CARD_4.0.0_ShortBRED_markers.faa

    BLASTDB=/scratch/asorgen/blast/db/v4
    TAXDUMP=/scratch/asorgen/NCBI_tax
    CARD_DB=/scratch/asorgen/RGI_databases/rgi_4.0.1
    METAPHLAN4_DB=/scratch/asorgen/metaphlan4_db

# Email address to receive job completion updates --------------------------------------------------
    email=aliciasorgen0@gmail.com

# Pre-QC -------------------------------------------------------------------------------------------
    pre_qc_opts="--partition=Orion --nodes=1 --ntasks-per-node=32 --mem=128GB --time=00:30:00 --mail-user=${email} --mail-type=FAIL"
    R1_ext=R1_001.fastq.gz
    R2_ext=R2_001.fastq.gz

# Deduplication ------------------------------------------------------------------------------------
    dedup_opts="--partition=Orion --nodes=1 --ntasks-per-node=32 --mem=128GB --time=01:30:00 --mail-user=${email} --mail-type=FAIL"

# Sequence trimming & quality filtering ------------------------------------------------------------
    trim_opts="--partition=Orion --nodes=1 --ntasks-per-node=8 --mem=32GB --time=05:00:00 --mail-user=${email} --mail-type=FAIL"

# Host decontamination -----------------------------------------------------------------------------
    decontam_opts="--partition=Orion --nodes=1 --ntasks-per-node=32 --mem=136GB --time=02:00:00 --mail-user=${email} --mail-type=FAIL"

# Assembly -----------------------------------------------------------------------------------------
    asm_opts="--partition=Orion --nodes=1 --cpus-per-task=48 --mem=256GB --time=128:00:00 --mail-user=${email} --mail-type=FAIL"

# Evaluation ---------------------------------------------------------------------------------------
    eval_opts="--partition=Orion --nodes=1 --cpus-per-task=1 --mem=1GB --time=01:00:00 --mail-user=${email} --mail-type=FAIL"

# Kraken2 ------------------------------------------------------------------------------------------
    k2_opts="--partition=Orion --nodes=1 --cpus-per-task=16 --mem=256GB --time=00:45:00 --mail-user=${email} --mail-type=FAIL"

# MetaPhlAn4 ---------------------------------------------------------------------------------------
    m4_opts="--partition=Orion --nodes=1 --cpus-per-task=16 --mem=256GB --time=00:45:00 --mail-user=${email} --mail-type=FAIL"

# Binning ------------------------------------------------------------------------------------------
    bin_opts="--partition=Orion --nodes=1 --cpus-per-task=12 --mem=128GB --time=00:05:00 --mail-user=${email} --mail-type=END,FAIL"

# Refinement ---------------------------------------------------------------------------------------
    refine_opts="--partition=Orion --nodes=1 --cpus-per-task=48 --mem=128GB --time=05:00:00 --mail-user=${email} --mail-type=END,FAIL"
    min_completion=70
    max_contam=10

# Reassembly ---------------------------------------------------------------------------------------
    reassem_opts="--partition=Orion --nodes=1 --cpus-per-task=8 --mem=140GB --time=24:00:00 --mail-user=${email} --mail-type=END,FAIL"

# Classification -----------------------------------------------------------------------------------
    classify_opts="--partition=Orion --nodes=1 --cpus-per-task=48 --mem=256GB --time=05:00:00 --mail-user=${email} --mail-type=FAIL"

# Annotation ---------------------------------------------------------------------------------------
    annotate_opts="--partition=Orion --nodes=1 --cpus-per-task=48 --mem=16GB --time=05:00:00 --mail-user=${email} --mail-type=FAIL"

# AMR detection ------------------------------------------------------------------------------------
    amr_opts="--partition=Orion --nodes=1 --cpus-per-task=8 --mem=8GB --time=05:00:00 --mail-user=${email} --mail-type=FAIL"   

# Assembly Gene Profiling --------------------------------------------------------------------------
    asm_profile_opts="--partition=Orion --nodes=1 --cpus-per-task=24 --mem=80GB --time=48:00:00 --mail-user=${email} --mail-type=FAIL"

# ShortBRED AMR detection --------------------------------------------------------------------------
    shortbred_opts="--partition=Orion --nodes=1 --cpus-per-task=24 --mem=16GB --time=05:30:00 --mail-user=${email} --mail-type=FAIL"

# RGI bwt AMR detection-----------------------------------------------------------------------------
    rgi_bwt_opts="--partition=Orion --nodes=1 --cpus-per-task=16 --mem=128GB --time=3:00:00 --mail-user=${email} --mail-type=FAIL"

# Pipeline clean up --------------------------------------------------------------------------------
    discard_opts="--partition=Orion --nodes=1 --cpus-per-task=1 --mem=1GB --time=00:05:00 --mail-user=${email} --mail-type=END"


# DO NOT CHANGE
readType=short_read
